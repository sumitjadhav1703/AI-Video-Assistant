# Copy to .env and fill in real values. Never commit .env — it is gitignored.

# ── LLM: summaries, extraction, chat, and mistral-embed embeddings ────────────
MISTRAL_API_KEY=

# ── Speech-to-text: English (Groq, whisper-large-v3-turbo) ────────────────────
GROQ_API_KEY=
# Optional override; defaults to whisper-large-v3-turbo
GROQ_STT_MODEL=

# ── Speech-to-text: Hinglish (Sarvam) ─────────────────────────────────────────
SARVAM_API_KEY=
# Optional override; defaults to saaras:v2.5
# NOTE: the code reads SARVAM_STT_MODEL (STT). Your existing .env has this
# spelled SARVAM_SST_MODEL (SST), so the override has never taken effect.
SARVAM_STT_MODEL=

# ── Persistent storage: Neon serverless Postgres (pgvector extension) ─────────
# Neon gives you a connection string like:
#   postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── CORS: exact origin of the deployed Streamlit frontend ─────────────────────
# Comma-separated for multiple. Defaults to http://localhost:8501 if unset.
#   https://your-app.streamlit.app
FRONTEND_ORIGIN=

# ── yt-dlp: optional browser-exported cookies to reduce YouTube blocking ──────
# Path to a cookies.txt file. Leave blank to run without cookies.
YT_DLP_COOKIES_PATH=

# ── Max upload size in MB. Oversized uploads get a clean 413. Defaults to 200. ─
MAX_UPLOAD_MB=

# ── Admin token for POST /admin/cleanup (purge old jobs + their vectors) ───────
# Send it as the X-Admin-Token header. Leave blank to disable the endpoint
# entirely (it returns 503 until a token is set). Use a long random string.
ADMIN_TOKEN=

# ── Optional HuggingFace read token ───────────────────────────────────────────
# MistralAIEmbeddings anonymously downloads its tokenizer from the HF Hub, which
# logs "You are sending unauthenticated requests to the HF Hub". Setting a free
# HF read token raises the rate limit and silences that warning. Purely optional.
HF_TOKEN=
